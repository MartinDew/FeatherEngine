{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 25,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "debug-fbuild",
            "displayName": "Debug",
            "description": "Debug build with full debug symbols and no optimization",
            "inherits": [
                "debug"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "USE_LLVM": "ON"
            },
            "generator": "FASTBuild"
        },
        {
            "name": "release-fbuild",
            "displayName": "Release",
            "description": "Release build with full optimization",
            "inherits": [
                "release"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "USE_LLVM": "ON"
            },
            "generator": "FASTBuild"
        },
        {
            "name": "development-fbuild",
            "displayName": "Development",
            "description": "Development build with optimization and debug symbols",
            "inherits": [
                "development"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Development",
                "USE_LLVM": "ON"
            },
            "generator": "FASTBuild"
        },
        {
            "name": "debug-vulkan-fbuild",
            "displayName": "Debug (Vulkan)",
            "description": "Debug build with full debug symbols and no optimization",
            "inherits": [
                "debug"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "USE_LLVM": "ON",
                "VEX_GRAPHICS_BACKEND": "VULKAN"
            },
            "generator": "FASTBuild"
        },
        {
            "name": "release-vulkan-fbuild",
            "displayName": "Release",
            "description": "Release build with full optimization",
            "inherits": [
                "release"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "USE_LLVM": "ON",
                "VEX_GRAPHICS_BACKEND": "VULKAN"
            },
            "generator": "FASTBuild"
        },
        {
            "name": "development-vulkan-fbuild",
            "displayName": "Development",
            "description": "Development build with optimization and debug symbols",
            "inherits": [
                "development"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Development",
                "USE_LLVM": "ON",
                "VEX_GRAPHICS_BACKEND": "VULKAN"
            },
            "generator": "FASTBuild"
        }
    ],
    "buildPresets": [
        {
            "name": "debug-fbuild",
            "displayName": "Debug Build",
            "configurePreset": "debug-fbuild",
            "nativeToolOptions": [
                "-dist",
                "-cache"
            ]
        },
        {
            "name": "release-fbuild",
            "displayName": "Release Build",
            "configurePreset": "release-fbuild",
            "nativeToolOptions": [
                "-dist",
                "-cache"
            ]
        },
        {
            "name": "development-fbuild",
            "displayName": "Development Build",
            "configurePreset": "development-fbuild",
            "configuration": "Development",
            "nativeToolOptions": [
                "-dist",
                "-cache"
            ]
        },        {
            "name": "debug-vulkan-fbuild",
            "displayName": "Debug Build",
            "configurePreset": "debug-vulkan-fbuild",
            "nativeToolOptions": [
                "-dist",
                "-cache"
            ]
        },
        {
            "name": "release-vulkan-fbuild",
            "displayName": "Release Build",
            "configurePreset": "release-vulkan-fbuild",
            "nativeToolOptions": [
                "-dist",
                "-cache"
            ]
        },
        {
            "name": "development-vulkan-fbuild",
            "displayName": "Development Build",
            "configurePreset": "development-vulkan-fbuild",
            "configuration": "Development",
            "nativeToolOptions": [
                "-dist",
                "-cache"
            ]
        }
    ]
}